# Backend Environment Variables (FastAPI + Uvicorn)
ENV=development

# API Server Configuration
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# Model Configuration
CLIP_MODEL=ViT-H/14
CLIP_PRETRAINED=openai
MEDCLIP_ENABLED=true
DEVICE=cuda  # or cpu if CUDA not available

# CORS Configuration (allow frontend connection)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000"]

# LLM Configuration - OpenAI + Gemini
# Provider priority: auto (OpenAI first, then Gemini), openai, or gemini
LLM_PROVIDER=auto

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
# Examples: gpt-4.1-mini, gpt-4o-mini
OPENAI_MODEL=gpt-4.1-mini

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
# Examples: gemini-2.0-flash, gemini-2.0-flash-lite
GEMINI_MODEL=gemini-2.0-flash

# Evaluation & Dataset
DATASET_PATH=backend/evaluation/
REFERENCE_PREDICTIONS_PATH=backend/reference_predictions.json

# Logging
LOG_LEVEL=INFO
